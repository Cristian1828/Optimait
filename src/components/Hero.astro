---
const waLink = 'https://wa.me/51921445800?text=Hola%2C%20necesito%20asesor%C3%ADa%20t%C3%A9cnica%20de%20OptimaIT.';
---

<section class="hero" id="inicio">
  <div class="hero-bg">
    <img src="/images/hero-bg.png" alt="Centro de operaciones tecnológicas profesional" loading="eager" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badge">
      <span class="badge">Consultoría & Soporte TI Gestionado</span>
    </div>
    <h1>Soluciones Tecnológicas<br/>y Soporte Especializado</h1>
    <p class="hero-subtitle">
      Optimizamos sus sistemas, gestionamos su infraestructura digital y desarrollamos software a medida. 
      Soporte remoto profesional para empresas que exigen rendimiento y seguridad.
    </p>
    <div class="hero-actions">
      <a href="#servicios" class="btn btn-primary">Ver Planes de Servicio</a>
      <a href={waLink} target="_blank" rel="noopener" class="btn btn-outline">Solicitar Auditoría</a>
    </div>

    <div class="hero-stats">
      <div class="stat-card glass">
        <span class="stat-number">99.8%</span>
        <span class="stat-label">Uptime Garantizado</span>
      </div>
      <div class="stat-card glass">
        <span class="stat-number">24/7</span>
        <span class="stat-label">Monitoreo Activo</span>
      </div>
      <div class="stat-card glass">
        <span class="stat-number">+200</span>
        <span class="stat-label">Sistemas Optimizados</span>
      </div>
      <div class="stat-card glass">
        <span class="stat-number">&lt;15min</span>
        <span class="stat-label">Tiempo de Respuesta</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 72px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 80px 0 60px;
  }

  .hero-badge {
    margin-bottom: 24px;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    max-width: 700px;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 580px;
    margin-bottom: 40px;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 60px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 700px;
  }

  .stat-card {
    padding: 20px 16px;
    border-radius: var(--radius-md);
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary-light);
    margin-bottom: 4px;
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 72px;
    }

    .hero-content {
      padding: 60px 0 40px;
    }

    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }

    .hero-actions {
      margin-bottom: 40px;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>

---
const waLink = 'https://wa.me/51921445800?text=Hola%2C%20me%20interesa%20contratar%20un%20plan%20de%20mantenimiento%20TI%20de%20OptimaIT.';
const plans = [
  {
    name: 'Optimización Estándar',
    price: '9.00',
    period: '/mes',
    description: 'Mantenimiento preventivo mensual para sistemas individuales.',
    features: [
      'Limpieza de archivos temporales',
      'Optimización de procesos de inicio',
      'Escaneo preventivo de seguridad remota',
      'Informe de rendimiento básico',
      'Soporte por ticket'
    ],
    highlighted: false,
    badge: null
  },
  {
    name: 'Mantenimiento Avanzado',
    price: '27.00',
    period: '/trimestre',
    description: 'Cobertura trimestral con soporte técnico prioritario.',
    features: [
      'Actualización de controladores',
      'Configuración de seguridad de red doméstica',
      'Soporte técnico prioritario',
      'Diagnóstico de rendimiento avanzado',
      'Soporte por chat directo'
    ],
    highlighted: false,
    badge: null
  },
  {
    name: 'Soporte Integral',
    price: '49.00',
    period: '/semestre',
    description: 'Seguridad avanzada y asistencia técnica bajo demanda.',
    features: [
      'Auditoría de seguridad avanzada',
      'Eliminación de malware',
      'Configuración de copias de seguridad automatizadas',
      'Asistencia técnica bajo demanda',
      'Soporte remoto prioritario'
    ],
    highlighted: true,
    badge: 'Más Popular'
  },
  {
    name: 'Gestión VIP Corporativa',
    price: '95.00',
    period: '/año',
    description: 'Membresía premium con soporte 24/7 y consultoría dedicada.',
    features: [
      'Soporte técnico 24/7 dedicado',
      'Monitoreo de rendimiento a nivel de registro',
      'Consultoría técnica personalizada',
      'Recuperación de datos lógicos',
      'Gestión de seguridad avanzada'
    ],
    highlighted: false,
    badge: 'Enterprise'
  }
];
---

<section class="section" id="servicios" style="background: var(--gradient-section);">
  <div class="container">
    <div class="section-header">
      <span class="badge">Planes de Mantenimiento TI</span>
      <h2>Soluciones Escalables para Cada Necesidad</h2>
      <p>Desde optimización básica hasta gestión corporativa completa. Todos los servicios son de entrega digital y asistencia 100% remota.</p>
    </div>

    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`pricing-card ${plan.highlighted ? 'pricing-card--highlighted' : ''}`}>
          {plan.badge && <span class="pricing-badge">{plan.badge}</span>}
          <h3 class="pricing-name">{plan.name}</h3>
          <p class="pricing-desc">{plan.description}</p>
          <div class="pricing-price">
            <span class="pricing-currency">$</span>
            <span class="pricing-amount">{plan.price}</span>
            <span class="pricing-period">USD {plan.period}</span>
          </div>
          <ul class="pricing-features">
            {plan.features.map((feature) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M13.3 4.3L6 11.6L2.7 8.3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a href={waLink} target="_blank" rel="noopener" class={`btn ${plan.highlighted ? 'btn-primary' : 'btn-outline'} pricing-cta`}>
            Comenzar Ahora
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: stretch;
  }

  .pricing-card {
    position: relative;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-card);
    transition: var(--transition-smooth);
  }

  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-hover);
  }

  .pricing-card--highlighted {
    border-color: var(--color-primary);
    background: linear-gradient(180deg, rgba(74, 127, 167, 0.08) 0%, var(--color-bg-surface) 40%);
    box-shadow: var(--shadow-card), 0 0 40px rgba(74, 127, 167, 0.1);
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 20px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--gradient-primary);
    color: var(--color-text);
    border-radius: 50px;
    white-space: nowrap;
  }

  .pricing-name {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .pricing-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-currency {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary-light);
    margin-right: 2px;
  }

  .pricing-amount {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1;
  }

  .pricing-period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-left: 4px;
  }

  .pricing-features {
    list-style: none;
    flex: 1;
    margin-bottom: 28px;
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--color-accent);
    padding: 8px 0;
    line-height: 1.4;
  }

  .pricing-features li svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-primary-light);
  }

  .pricing-cta {
    width: 100%;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 600px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
